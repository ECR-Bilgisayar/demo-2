# SendGrid API key for the registration confirmation email
SENDGRID_API_KEY=your-sendgrid-api-key

# From address for outgoing registration emails
SENDGRID_FROM_EMAIL=info@etkinlikbilgisayar.com

# Optional PocketBase URL for saving event registrations
# If not set, only SendGrid email confirmation is sent.
VITE_POCKETBASE_URL=http://127.0.0.1:8090
